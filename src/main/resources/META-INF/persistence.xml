<?xml version="1.0" encoding="UTF-8"?>

<persistence
        xmlns="https://jakarta.ee/xml/ns/persistence"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
            https://jakarta.ee/xml/ns/persistence
            https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd"
        version="3.1">

    <persistence-unit name="MiniMesPU" transaction-type="JTA">

        <jta-data-source>java:/jdbc/MiniMesDS</jta-data-source>

        <class>de.denis.mes.entity.Maschine</class>
        <class>de.denis.mes.entity.Auftrag</class>

        <properties>
            <property
                    name="jakarta.persistence.schema-generation.database.action"
                    value="none"/>
        </properties>

    </persistence-unit>

</persistence>